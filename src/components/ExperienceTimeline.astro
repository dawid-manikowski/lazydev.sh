---
const jobs = [
  {
    company: 'CaptivateIQ',
    role: 'Senior SRE / Tech Lead',
    period: '2021 — Present',
    description: 'First SRE hire at a US-based, VC-backed startup. Led the migration from Heroku to AWS (ECS, Fargate, RDS, VPC) single-handedly in 4 months. Drove company-wide SLO adoption across all dev teams. Led the EU region deployment and played a key role in the AU region rollout. Day-to-day: PostgreSQL migrations, AWS infrastructure architecture, Terraform, Python automation, monitoring, and supporting engineering teams.',
  },
  {
    company: 'Makeitright',
    role: 'Lead DevOps Engineer',
    period: '2018 — 2021',
    description: 'Sole DevOps engineer, later leading a team of up to 4. Owned CI/CD (Jenkins), release pipelines, security, installers, and IaC (Terraform) for Powerfarm — an on-prem product deployed at banks and insurance companies. Represented the company as a technical specialist at client meetings and managed on-site deployments. Also worked on the SaaS rewrite (Powerfarm 2.0).',
  },
  {
    company: 'Samsung R&D Poland',
    role: 'Junior DevOps Engineer',
    period: '2018 — 2018',
    description: 'Python scripting and internal tooling for other development teams. Quickly outgrew the role — led the team technically despite the junior title.',
  },
  {
    company: 'Reef Technologies',
    role: 'Junior Python Developer',
    period: '2017 - 2018',
    description: 'Backend Python development, mostly open-source work (Backblaze B2). Sharpened core Python skills in a demanding environment.',
  },
  {
    company: 'Intel Technology Poland',
    role: 'Intern → Software Engineer',
    period: '2015 — 2017',
    description: 'Started as an intern after winning 2nd place at a Gdańsk University of Technology hackathon (Smart Traffic Lights). Worked on test automation and tooling around USB drivers, Simics, and audio drivers. Transitioned to full-time after completing engineering degree.',
  },
  {
    company: 'mPicoSys',
    role: 'Engineering Intern',
    period: '2014 — 2015',
    description: 'Student internship at a company building e-ink display devices. Firmware flashing, Python scripting for database analysis, and hardware testing in thermal chambers.',
  },
];

const education = [
  {
    institution: 'Gdańsk University of Technology',
    degree: 'B.Eng. in Electronics & Telecommunications',
    period: '2011 — 2015',
    description: 'Faculty of Electronics, Telecommunications and Informatics. Department of Computer Electronic Systems.',
  },
];
---

<div class="timeline">
  {jobs.map((job) => (
    <div class="timeline__item">
      <div class="timeline__marker"></div>
      <div class="timeline__content">
        <div class="timeline__header">
          <h3 class="timeline__company">{job.company}</h3>
          <span class="timeline__period">{job.period}</span>
        </div>
        <p class="timeline__role">{job.role}</p>
        <p class="timeline__desc">{job.description}</p>
      </div>
    </div>
  ))}
</div>

<h2 class="section-title">Education</h2>

<div class="timeline">
  {education.map((edu) => (
    <div class="timeline__item">
      <div class="timeline__marker"></div>
      <div class="timeline__content">
        <div class="timeline__header">
          <h3 class="timeline__company">{edu.institution}</h3>
          <span class="timeline__period">{edu.period}</span>
        </div>
        <p class="timeline__role">{edu.degree}</p>
        <p class="timeline__desc">{edu.description}</p>
      </div>
    </div>
  ))}
</div>

<style>
  .timeline {
    position: relative;
    padding-left: var(--space-xl);
  }

  .timeline::before {
    content: '';
    position: absolute;
    left: 5px;
    top: 8px;
    bottom: 8px;
    width: 1px;
    background: var(--border);
  }

  .timeline__item {
    position: relative;
    padding-bottom: var(--space-xl);
  }

  .timeline__item:last-child {
    padding-bottom: 0;
  }

  .timeline__marker {
    position: absolute;
    left: calc(-1 * var(--space-xl) + 1px);
    top: 8px;
    width: 9px;
    height: 9px;
    background: var(--accent);
  }

  .timeline__header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--space-md);
    margin-bottom: var(--space-xs);
  }

  .timeline__company {
    font-size: 1rem;
    text-transform: uppercase;
  }

  .timeline__period {
    font-family: var(--font-heading);
    font-size: 0.75rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    white-space: nowrap;
  }

  .timeline__role {
    font-size: 0.875rem;
    color: var(--accent);
    margin-bottom: var(--space-sm);
  }

  .timeline__desc {
    font-size: 0.875rem;
    color: var(--text-muted);
    line-height: 1.6;
  }

  .section-title {
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--accent);
    margin-top: var(--space-xl);
    margin-bottom: var(--space-lg);
  }

  @media (max-width: 768px) {
    .timeline__header {
      flex-direction: column;
      gap: 0;
    }
  }
</style>
