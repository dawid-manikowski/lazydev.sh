---
import { getCollection, render } from 'astro:content';
import BlogLayout from '../../layouts/BlogLayout.astro';
import { readingTimeOf } from '../../utils/reading-time';
import { blogPostingJsonLd, breadcrumbJsonLd } from '../../utils/json-ld';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const readingTime = readingTimeOf(post.body ?? '');

const blogPosting = blogPostingJsonLd({
  title: post.data.title,
  description: post.data.description,
  slug: post.id,
  publishedTime: post.data.pubDate.toISOString(),
  modifiedTime: post.data.updatedDate?.toISOString(),
  author: post.data.author ?? 'Dawid Manikowski',
  tags: post.data.tags,
  ogImage: post.data.ogImage,
  readingTimeIso8601: readingTime.iso8601,
});
const breadcrumb = breadcrumbJsonLd(post.data.title, post.id);
---

<BlogLayout
  frontmatter={{
    ...post.data,
    pubDate: post.data.pubDate.toISOString(),
    updatedDate: post.data.updatedDate?.toISOString(),
  }}
  readingTime={readingTime}
  jsonLd={[blogPosting, breadcrumb]}
>
  <Content />
</BlogLayout>
