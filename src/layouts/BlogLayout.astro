---
import BaseLayout from './BaseLayout.astro';
import type { ReadingTime } from '../utils/reading-time';

interface Props {
  frontmatter: {
    title: string;
    description: string;
    pubDate: string;
    updatedDate?: string;
    tags?: string[];
    author?: string;
    ogImage?: string;
  };
  readingTime?: ReadingTime;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const { frontmatter, readingTime, jsonLd } = Astro.props;

const fmt = (d: string) =>
  new Date(d).toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });

const publishedDate = fmt(frontmatter.pubDate);
const updatedDate = frontmatter.updatedDate ? fmt(frontmatter.updatedDate) : null;

const articleMeta = {
  publishedTime: frontmatter.pubDate,
  modifiedTime: frontmatter.updatedDate,
  author: frontmatter.author ?? 'Dawid Manikowski',
  tags: frontmatter.tags,
};
---

<BaseLayout
  title={frontmatter.title}
  description={frontmatter.description}
  ogImage={frontmatter.ogImage}
  article={articleMeta}
  jsonLd={jsonLd}
>
  <main class="container">
    <article class="blog-post">
      <header class="blog-post__header">
        <h1>{frontmatter.title}</h1>
        <div class="blog-post__meta">
          <time datetime={frontmatter.pubDate}>{publishedDate}</time>
          {updatedDate && (
            <span class="blog-post__updated">
              · Updated <time datetime={frontmatter.updatedDate}>{updatedDate}</time>
            </span>
          )}
          {readingTime && (
            <span class="blog-post__reading-time">· {readingTime.minutes} min read</span>
          )}
          {frontmatter.tags && (
            <div class="blog-post__tags">
              {frontmatter.tags.map((tag: string) => (
                <span class="tag">{tag}</span>
              ))}
            </div>
          )}
        </div>
      </header>
      <div class="blog-post__content">
        <slot />
        <div class="blog-post__rss">
          Liked the post? Follow via <a href="/rss.xml">RSS</a> for more!
        </div>
      </div>
    </article>
  </main>
</BaseLayout>

<style>
  .blog-post {
    max-width: var(--content-width);
    margin: 0 auto;
    padding: var(--space-2xl) 0;
  }

  .blog-post__header {
    margin-bottom: var(--space-xl);
    padding-bottom: var(--space-lg);
    border-bottom: 1px solid var(--border);
  }

  .blog-post__header h1 {
    margin-bottom: var(--space-md);
  }

  .blog-post__meta {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    color: var(--text-muted);
    font-size: 0.875rem;
  }

  .blog-post__tags {
    display: flex;
    gap: var(--space-sm);
  }

  .tag {
    font-family: var(--font-heading);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--accent);
    border: 1px solid var(--border);
    padding: 0.15em 0.5em;
  }

  .blog-post__content {
    line-height: 1.8;
  }

  .blog-post__content :global(h2) {
    margin-top: var(--space-xl);
    margin-bottom: var(--space-md);
  }

  .blog-post__content :global(h3) {
    margin-top: var(--space-lg);
    margin-bottom: var(--space-sm);
  }

  .blog-post__content :global(p) {
    margin-bottom: var(--space-md);
  }

  .blog-post__content :global(ul),
  .blog-post__content :global(ol) {
    margin-bottom: var(--space-md);
    padding-left: var(--space-lg);
  }

  .blog-post__content :global(li) {
    margin-bottom: var(--space-xs);
  }

  .blog-post__content :global(pre) {
    margin-bottom: var(--space-md);
  }

  .blog-post__content :global(blockquote) {
    border-left: 3px solid var(--accent);
    padding-left: var(--space-md);
    color: var(--text-muted);
    margin-bottom: var(--space-md);
  }

  .blog-post__updated {
    color: var(--text-muted);
  }

  .blog-post__reading-time {
    color: var(--text-muted);
  }

  .blog-post__content :global(.heading-anchor) {
    color: var(--text-muted);
    text-decoration: none;
    margin-left: 0.5em;
    opacity: 0;
    transition: opacity 120ms ease-in;
  }

  .blog-post__content :global(h2:hover .heading-anchor),
  .blog-post__content :global(h3:hover .heading-anchor),
  .blog-post__content :global(.heading-anchor:focus) {
    opacity: 1;
  }

  .blog-post__rss {
    margin-top: var(--space-xl);
    padding: var(--space-md);
    border: 1px solid var(--border);
  }

  .blog-post__rss a {
    color: var(--text);
    text-decoration: underline;
  }

  .blog-post__rss a:hover {
    color: var(--accent);
  }
</style>
